         mstwpdf`Private`x = N[mstwpdf`Private`xin]; 
         mstwpdf`Private`q = N[mstwpdf`Private`qin]; 
         mstwpdf`Private`qsq = mstwpdf`Private`q mstwpdf`Private`q; If[
           Or[Im[mstwpdf`Private`x] != 0, Im[mstwpdf`Private`q] != 0], {}]; If[
