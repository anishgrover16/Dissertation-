Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"--", 
     RowBox[{"-", 
      RowBox[{"Inputs", "--"}]}]}], "-"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"sqrts", "=", "8000."}], ";"}], "\n", 
   RowBox[{
    RowBox[{"ih", "=", "0"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"rows", "=", 
     RowBox[{"Normal", "[", "dsKin6", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"row", "=", 
     RowBox[{"rows", "[", 
      RowBox[{"[", "5", "]"}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ptLow", "=", 
     RowBox[{"row", "[", "\"\<PTAVG [GeV]\>\"", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"ptHigh", "=", 
     RowBox[{
      RowBox[{"rows", "[", 
       RowBox[{"[", "6", "]"}], "]"}], "[", "\"\<PTAVG [GeV]\>\"", "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"pt", "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"ptLow", "+", "ptHigh"}], ")"}], "/", "2"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"--", 
       RowBox[{"-", "Rapidity"}]}], " ", "bin", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"Table", " ", "1"}], ")"}], "--"}]}], "-"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"yBmin", "=", "2."}], ";", 
    RowBox[{"yBmax", "=", "3."}], ";"}], "\n", 
   RowBox[{
    RowBox[{"ySmin", "=", "0."}], ";", 
    RowBox[{"ySmax", "=", "1."}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"--", 
      RowBox[{"-", "Fix"}]}], " ", "yB", " ", "midpoint"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"yB", "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"yBmin", "+", "yBmax"}], ")"}], "/", "2"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"--", 
      RowBox[{"-", "x1"}]}], " ", "range", " ", "from", " ", "bin"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"x1min", ",", "x1max"}], "}"}], "=", 
     RowBox[{"row", "/@", 
      RowBox[{"{", 
       RowBox[{"\"\<x1_min\>\"", ",", "\"\<x1_max\>\""}], "}"}]}]}], ";"}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"x1vals", "=", 
     RowBox[{"Subdivide", "[", 
      RowBox[{"x1min", ",", 
       RowBox[{"x1max", "-", 
        RowBox[{"10", "^", 
         RowBox[{"-", "4"}]}]}], ",", "60"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"--", 
      RowBox[{"-", "Build"}]}], " ", "gg", " ", "vs", " ", "x1", " ", "using",
      " ", "solved", " ", "y", "*", 
     RowBox[{"--", "-"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ggScan", "=", 
     RowBox[{"Cases", "[", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"Module", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"coshys", ",", "ys", ",", "x2", ",", "val"}], "}"}], ",", 
           
           RowBox[{"(*", 
            RowBox[{"solve", " ", "for", " ", "y", "*"}], "*)"}], 
           RowBox[{
            RowBox[{"coshys", "=", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"x1", "*", "sqrts"}], ")"}], "/", 
              RowBox[{"(", 
               RowBox[{"2", " ", "pt", " ", 
                RowBox[{"Exp", "[", "yB", "]"}]}], ")"}]}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"coshys", "<", "1"}], ",", 
              RowBox[{"Return", "[", "Nothing", "]"}]}], "]"}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"ys", "=", 
             RowBox[{"ArcCosh", "[", "coshys", "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"(*", 
             RowBox[{"enforce", " ", "bin", " ", "constraint"}], "*)"}], 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"ys", "<", "ySmin"}], "||", 
               RowBox[{"ys", ">", "ySmax"}]}], ",", 
              RowBox[{"Return", "[", "Nothing", "]"}]}], "]"}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"(*", 
             RowBox[{"compute", " ", "x2"}], "*)"}], 
            RowBox[{"x2", "=", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"2", " ", 
                RowBox[{"pt", "/", "sqrts"}]}], ")"}], " ", 
              RowBox[{"Exp", "[", 
               RowBox[{"-", "yB"}], "]"}], " ", 
              RowBox[{"Cosh", "[", "ys", "]"}]}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"x2", "<=", "0"}], "||", 
               RowBox[{"x2", ">=", "1"}]}], ",", 
              RowBox[{"Return", "[", "Nothing", "]"}]}], "]"}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"val", "=", 
             RowBox[{
              RowBox[{"xf", "[", 
               RowBox[{"ih", ",", "x1", ",", "pt", ",", "0"}], "]"}], "*", 
              RowBox[{"xf", "[", 
               RowBox[{"ih", ",", "x2", ",", "pt", ",", "0"}], "]"}]}]}], ";",
             "\[IndentingNewLine]", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"NumericQ", "[", "val", "]"}], "&&", 
               RowBox[{"val", ">", "0"}]}], ",", 
              RowBox[{"{", 
               RowBox[{"x1", ",", "val"}], "}"}], ",", "Nothing"}], "]"}]}]}],
           "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"x1", ",", "x1vals"}], "}"}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"_", "?", "NumericQ"}], ",", 
         RowBox[{"_", "?", "NumericQ"}]}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"--", 
      RowBox[{"-", 
       RowBox[{"Plot", "--"}]}]}], "-"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"ListLinePlot", "[", 
    RowBox[{"ggScan", ",", 
     RowBox[{"Frame", "->", "True"}], ",", 
     RowBox[{"FrameLabel", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Style", "[", 
         RowBox[{"\"\<x1\>\"", ",", "16"}], "]"}], ",", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<xg(x1,Q) * xg(x2,Q)\>\"", ",", "16"}], "]"}]}], "}"}]}],
      ",", 
     RowBox[{"LabelStyle", "->", 
      RowBox[{"Directive", "[", "14", "]"}]}], ",", 
     RowBox[{"PlotStyle", "->", 
      RowBox[{"Directive", "[", 
       RowBox[{"Blue", ",", "Thick"}], "]"}]}], ",", 
     RowBox[{"ScalingFunctions", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<Log\>\"", ",", "\"\<Log\>\""}], "}"}]}], ",", 
     RowBox[{"PlotRange", "->", "All"}], ",", 
     RowBox[{"ImageSize", "->", "500"}], ",", 
     RowBox[{"Epilog", "->", 
      RowBox[{"{", 
       RowBox[{"Text", "[", 
        RowBox[{
         RowBox[{"Style", "[", 
          RowBox[{
           RowBox[{"\"\<yB = 2.5, y* = [0,1], pT \[TildeTilde] \>\"", "<>", 
            RowBox[{"ToString", "[", 
             RowBox[{"NumberForm", "[", 
              RowBox[{"pt", ",", 
               RowBox[{"{", 
                RowBox[{"5", ",", "1"}], "}"}]}], "]"}], "]"}], 
            "<>", "\"\< GeV\>\""}], ",", "14", ",", "Bold"}], "]"}], ",", 
         RowBox[{"Scaled", "[", 
          RowBox[{"{", 
           RowBox[{"0.6", ",", "0.85"}], "}"}], "]"}]}], "]"}], "}"}]}]}], 
