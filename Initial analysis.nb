Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Function", " ", "to", " ", "call", " ", "specific", " ", "tables", " ", 
    "when", " ", "needed"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"toNumber", "[", "x_", "]"}], ":=", 
     RowBox[{"Which", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"StringQ", "[", "x", "]"}], "&&", 
        RowBox[{"StringContainsQ", "[", 
         RowBox[{"x", ",", "\"\<%\>\""}], "]"}]}], ",", 
       RowBox[{
        RowBox[{"ToExpression", "[", 
         RowBox[{"StringDrop", "[", 
          RowBox[{"x", ",", 
           RowBox[{"-", "1"}]}], "]"}], "]"}], "/", "100"}], ",", "True", ",", 
       RowBox[{"ToExpression", "[", "x", "]"}]}], "]"}]}], ";", 
    RowBox[{
     RowBox[{"loadTable", "[", "i_", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"raw", ",", "rows", ",", "header", ",", "data", ",", "ds"}], 
        "}"}], ",", 
       RowBox[{
        RowBox[{"raw", "=", 
         RowBox[{"Import", "[", 
          RowBox[{
           RowBox[{"hepdataPath", "<>", "\"\<Table\>\"", "<>", 
            RowBox[{"ToString", "[", "i", "]"}], "<>", "\"\<.csv\>\""}], 
           ",", "\"\<CSV\>\""}], "]"}]}], ";", 
        RowBox[{"rows", "=", 
         RowBox[{"Select", "[", 
          RowBox[{"raw", ",", 
           RowBox[{
            RowBox[{"!", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"StringQ", "@", 
                RowBox[{"First", "@", "#"}]}], "&&", 
               RowBox[{"StringStartsQ", "[", 
                RowBox[{
                 RowBox[{"First", "@", "#"}], ",", "\"\<#\>\""}], "]"}]}], 
              ")"}]}], "&"}]}], "]"}]}], ";", 
        RowBox[{"header", "=", 
         RowBox[{"rows", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ";", 
        RowBox[{"data", "=", 
         RowBox[{"rows", "[", 
          RowBox[{"[", 
           RowBox[{"2", ";;"}], "]"}], "]"}]}], ";", 
        RowBox[{"ds", "=", 
         RowBox[{"Dataset", "@", 
          RowBox[{"Map", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"AssociationThread", "[", 
              RowBox[{"header", "->", 
               RowBox[{"(", 
                RowBox[{"toNumber", "/@", "#"}], ")"}]}], "]"}], "&"}], ",", 
            "data"}], "]"}]}]}], ";", 
        RowBox[{"<|", 
         RowBox[{
          RowBox[{"\"\<header\>\"", "->", "header"}], ",", 
          RowBox[{"\"\<ds\>\"", "->", "ds"}]}], "|>"}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]"}]}]], "Input",
 CellChangeTimes->{
