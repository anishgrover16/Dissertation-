           mstwpdf`Private`f == 13, mstwpdf`Private`ip = 12, 
           And[Abs[mstwpdf`Private`f] != 6, mstwpdf`Private`f != 12], {
           Print["Error in xf: invalid f = ", mstwpdf`Private`f]; Abort[]; 
