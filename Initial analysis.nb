Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"sqrts", "=", "8000."}], ";"}], 
  "                                   ", 
  RowBox[{"(*", "GeV", "*)"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"yBmin", "=", "0.0"}], ";", 
   RowBox[{"yBmax", "=", "1.0"}], ";"}], "                        ", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Table", " ", "1"}], ":", 
    RowBox[{"y_boost", " ", "bin"}]}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"ySmin", "=", "1.0"}], ";", 
   RowBox[{"ySmax", "=", "2.0"}], ";"}], "                        ", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Table", " ", "1"}], ":", 
    RowBox[{"y_star", " ", "bin"}]}], "*)"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"t2", "=", 
    RowBox[{"loadTable", "[", "2", "]"}]}], ";"}], 
  "                               ", 
  RowBox[{"(*", 
   RowBox[{"load", " ", "Table", " ", "1"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"ds", "=", 
    RowBox[{"t2", "[", "\"\<ds\>\"", "]"}]}], ";"}], 
  "                                   ", 
  RowBox[{"(*", "dataset", "*)"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"dsKin2", "=", 
    RowBox[{"ds", "[", 
     RowBox[{"All", ",", 
      RowBox[{"Function", "[", 
       RowBox[{"row", ",", 
        RowBox[{"Module", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
           "pt", ",", "x1Min", ",", "x1Max", ",", "x2Min", ",", "x2Max", ",", 
            "x1cand", ",", "x2cand", ",", "yBallow", ",", "ySallow", ",", 
            "arg"}], "}"}], ",", 
          RowBox[{
           RowBox[{"pt", "=", 
            RowBox[{"row", "[", "\"\<PTAVG [GeV]\>\"", "]"}]}], ";", 
           RowBox[{"(*", 
            RowBox[{"fix", " ", "pT", " ", "for", " ", "this", " ", "row"}], 
            "*)"}], 
           RowBox[{"(*", 
            RowBox[{
             RowBox[{"--", 
              RowBox[{"--", "x1_min"}]}], " ", "at", " ", 
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"yBmin", ",", "ySmin"}], ")"}], "--"}], "--"}]}], 
            "*)"}], 
           RowBox[{"x1Min", "=", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"2", " ", 
               RowBox[{"pt", "/", "sqrts"}]}], ")"}], " ", 
             RowBox[{"Exp", "[", 
              RowBox[{"+", "yBmin"}], "]"}], " ", 
             RowBox[{"Cosh", "[", "ySmin", "]"}]}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"x1Min", ">", "1."}], ",", 
             RowBox[{"x1Min", "=", "1."}]}], "]"}], ";", 
           RowBox[{"(*", 
            RowBox[{
             RowBox[{"enforce", " ", "x1"}], "<=", "1"}], "*)"}], 
           RowBox[{"(*", 
            RowBox[{"--", 
             RowBox[{"--", 
              RowBox[{"x2_min", ":", 
               RowBox[{"start", " ", "from", " ", "corner", " ", 
                RowBox[{
                 RowBox[{
                  RowBox[{"(", 
                   RowBox[{"yBmax", ",", "ySmin"}], ")"}], "--"}], 
                 "--"}]}]}]}]}], "*)"}], 
           RowBox[{"x1cand", "=", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"2", " ", 
               RowBox[{"pt", "/", "sqrts"}]}], ")"}], " ", 
             RowBox[{"Exp", "[", 
              RowBox[{"+", "yBmax"}], "]"}], " ", 
             RowBox[{"Cosh", "[", "ySmin", "]"}]}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"x2cand", "=", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"2", " ", 
               RowBox[{"pt", "/", "sqrts"}]}], ")"}], " ", 
             RowBox[{"Exp", "[", 
              RowBox[{"-", "yBmax"}], "]"}], " ", 
             RowBox[{"Cosh", "[", "ySmin", "]"}]}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"x1cand", "<=", "1."}], ",", 
             RowBox[{
              RowBox[{"x2Min", "=", "x2cand"}], ";"}], ",", 
             RowBox[{"(*", 
              RowBox[{"corner", " ", "allowed"}], "*)"}], 
             RowBox[{
              RowBox[{"yBallow", "=", 
               RowBox[{"Log", "[", 
                RowBox[{"sqrts", "/", 
                 RowBox[{"(", 
                  RowBox[{"2", " ", "pt", " ", 
                   RowBox[{"Cosh", "[", "ySmin", "]"}]}], ")"}]}], "]"}]}], ";",
               "\[IndentingNewLine]", 
              RowBox[{"yBallow", "=", 
               RowBox[{"Min", "[", 
                RowBox[{
                 RowBox[{"Max", "[", 
                  RowBox[{"yBallow", ",", "yBmin"}], "]"}], ",", "yBmax"}], 
                "]"}]}], ";", "\[IndentingNewLine]", 
              RowBox[{"x2Min", "=", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"2", " ", 
                  RowBox[{"pt", "/", "sqrts"}]}], ")"}], " ", 
                RowBox[{"Exp", "[", 
                 RowBox[{"-", "yBallow"}], "]"}], " ", 
                RowBox[{"Cosh", "[", "ySmin", "]"}]}]}], ";"}]}], "]"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"(*", 
            RowBox[{"--", 
             RowBox[{"--", 
              RowBox[{"x2_max", ":", 
               RowBox[{"start", " ", "from", " ", "corner", " ", 
                RowBox[{
                 RowBox[{
                  RowBox[{"(", 
                   RowBox[{"yBmin", ",", "ySmax"}], ")"}], "--"}], 
                 "--"}]}]}]}]}], "*)"}], 
           RowBox[{"x1cand", "=", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"2", " ", 
               RowBox[{"pt", "/", "sqrts"}]}], ")"}], " ", 
             RowBox[{"Exp", "[", 
              RowBox[{"+", "yBmin"}], "]"}], " ", 
             RowBox[{"Cosh", "[", "ySmax", "]"}]}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"x2cand", "=", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"2", " ", 
               RowBox[{"pt", "/", "sqrts"}]}], ")"}], " ", 
             RowBox[{"Exp", "[", 
              RowBox[{"-", "yBmin"}], "]"}], " ", 
             RowBox[{"Cosh", "[", "ySmax", "]"}]}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"x1cand", "<=", "1."}], ",", 
             RowBox[{
              RowBox[{"x2Max", "=", "x2cand"}], ";"}], ",", 
             RowBox[{"(*", 
              RowBox[{"corner", " ", "allowed"}], "*)"}], 
             RowBox[{
              RowBox[{"arg", "=", 
               RowBox[{"sqrts", "/", 
                RowBox[{"(", 
                 RowBox[{"2", " ", "pt", " ", 
                  RowBox[{"Exp", "[", 
                   RowBox[{"+", "yBmin"}], "]"}]}], ")"}]}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{"arg", "<=", "1."}], ",", 
                RowBox[{
                 RowBox[{"x2Max", "=", "0."}], ";"}], ",", 
                RowBox[{"(*", 
                 RowBox[{"no", " ", "allowed", " ", "y", "*"}], "*)"}], 
                RowBox[{
                 RowBox[{"ySallow", "=", 
                  RowBox[{"ArcCosh", "[", "arg", "]"}]}], ";", 
                 "\[IndentingNewLine]", 
                 RowBox[{"ySallow", "=", 
                  RowBox[{"Min", "[", 
                   RowBox[{
                    RowBox[{"Max", "[", 
                    RowBox[{"ySallow", ",", "ySmin"}], "]"}], ",", "ySmax"}], 
                   "]"}]}], ";", "\[IndentingNewLine]", 
                 RowBox[{"x2Max", "=", 
                  RowBox[{
