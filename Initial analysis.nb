           Print["Error in xf: invalid (x,q) = (", mstwpdf`Private`x, ",", 
              mstwpdf`Private`q, ")"]; Abort[]; Null}, 
           Or[Abs[mstwpdf`Private`f] == 6, mstwpdf`Private`f == 12], 
           mstwpdf`Private`res = 0., mstwpdf`Private`qsq < 
           mstwpdf`Private`qsqmin, {
           If[mstwpdf`Private`x < mstwpdf`Private`xmin, {
              mstwpdf`Private`res = 
                mstwpdf`Private`ExtrapolatePDF[
                 mstwpdf`Private`ip, mstwpdf`Private`ih, mstwpdf`Private`xlog, 
